{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.Nodemint-dev/projectmind",
  "title": "projectmind",
  "description": "Persistent project memory for AI coding agents: one compact digest instead of re-reading the repo.",
  "repository": {
    "url": "https://github.com/Nodemint-dev/projectmind",
    "source": "github"
  },
  "version": "0.5.1",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@nodemint/projectmind",
      "version": "0.5.1",
      "runtimeHint": "npx",
      "transport": {
        "type": "stdio"
      },
      "packageArguments": [
        {
          "type": "positional",
          "value": "mcp",
          "description": "Run the stdio MCP server subcommand."
        }
      ]
    }
  ]
}
